# Resend API Configuration (Get from https://resend.com/api-keys)
RESEND_API_KEY=re_your_resend_api_key_here
FROM_EMAIL=onboarding@resend.dev
TO_EMAIL=your.email@example.com

# Google reCAPTCHA v3/v2 Secret Key (Get from https://www.google.com/recaptcha/admin)
RECAPTCHA_SECRET_KEY=your_google_recaptcha_secret_key_here
RECAPTCHA_MIN_SCORE=0.5

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,https://YOUR-VERCEL-DOMAIN.vercel.app

# Environment Mode
ENVIRONMENT=development
